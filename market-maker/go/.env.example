# ── Network ──────────────────────────────────────────────────────────────────
NETWORK=testnet   # testnet | mainnet  (sets default URLs and package address)

# ── Required ─────────────────────────────────────────────────────────────────
BEARER_TOKEN=your_rest_api_bearer_token_here
SUBACCOUNT_ADDRESS=0xYourSubaccountAddress
PRIVATE_KEY=0xYour32ByteEd25519PrivateKeyHex
# PERP_ENGINE_GLOBAL_ADDRESS is optional. If left empty and PACKAGE_ADDRESS is
# set, the bot will derive the value automatically from PACKAGE_ADDRESS using
# the named-object seed "GlobalPerpEngine". You can still override it here
# if you need to point at a different on-chain object.
PERP_ENGINE_GLOBAL_ADDRESS=0xPerpEngineGlobalAddress

# ── Optional overrides ────────────────────────────────────────────────────────
# PACKAGE_ADDRESS=0xYourMovePackageAddress   # optional; when set, the bot can auto-derive PERP_ENGINE_GLOBAL_ADDRESS
# NODE_API_KEY=your_fullnode_api_key        # falls back to BEARER_TOKEN
# APTOS_FULLNODE_URL=https://aptos.testnet.suzuka.movementlabs.xyz/v1
# REST_API_BASE=https://api.testnet.decibel.trade/v1
# MARKET_ADDR=0xOverridePerpMarketAddress   # skip API discovery

# ── Trading parameters ────────────────────────────────────────────────────────
# MARKET_NAME=BTC/USD
# SPREAD=0.001
# ORDER_SIZE=0.001
# MAX_INVENTORY=0.005
# SKEW_PER_UNIT=0.0001
# MAX_MARGIN_USAGE=0.5
# REFRESH_INTERVAL=20
# COOLDOWN_S=1.5
# CANCEL_RESYNC_S=8.0
# AUTO_FLATTEN=false
# FLATTEN_AGGRESSION=0.001
# DRY_RUN=true   # recommended for testing. Must be explicitly set via env or the -dry-run CLI flag; no automatic defaults are applied.
