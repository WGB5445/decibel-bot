# ── Network ──────────────────────────────────────────────────────────────────
NETWORK=testnet   # testnet | mainnet  (sets default URLs and package address)

# Optional JSON/YAML/TOML config (CLI -config overrides this). See examples/config/.
# CONFIG_FILE=examples/config/bot.example.yaml
# Minimal YAML template (network + a few trading fields; secrets left blank): go run . -init-config

# ── Required ─────────────────────────────────────────────────────────────────
BEARER_TOKEN=your_rest_api_bearer_token_here
SUBACCOUNT_ADDRESS=0xYourSubaccountAddress
PRIVATE_KEY=0xYour32ByteEd25519PrivateKeyHex

# ── Optional overrides ────────────────────────────────────────────────────────
# PACKAGE_ADDRESS=0xYourMovePackageAddress
# NODE_API_KEY=your_fullnode_api_key        # falls back to BEARER_TOKEN; CLI: -node-api-key
# APTOS_FULLNODE_URL=https://aptos.testnet.suzuka.movementlabs.xyz/v1
# REST_API_BASE=https://api.testnet.decibel.trade/v1
# MARKET_ADDR=0xOverridePerpMarketAddress   # skip API discovery

# ── Trading parameters ────────────────────────────────────────────────────────
# MARKET_NAME=BTC/USD
# SPREAD=0.001
# ORDER_SIZE=0.001
# MAX_INVENTORY=0.005
# SKEW_PER_UNIT=0.0001
# MAX_MARGIN_USAGE=0.5
# REFRESH_INTERVAL=20
# REFRESH_INTERVAL_JITTER_S=0   # uniform sleep in [REFRESH_INTERVAL−jitter, REFRESH_INTERVAL+jitter]; 0 = off
# COOLDOWN_S=1.5
# CANCEL_RESYNC_S=8.0
# Boolean CLI flags (-dry-run, -auto-flatten, …): see README.md section "Boolean flags" (under CLI flags).
# AUTO_FLATTEN=false
# FLATTEN_AGGRESSION=0.001
# DRY_RUN=false
